# =============================================================================
# .gitignore — pixel-ansible
# =============================================================================

# Never commit the vault password — it lives only on each device.
*/.vault_pass
.vault_pass

# Ansible retry files
*.retry

# Ansible temporary files
.ansible/

# Device identity files — generated by bootstrap.sh on each device.
# Do NOT add device_vars.yml here since the template lives in the repo.
# The actual ~/.ansible/device_vars.yml is outside the repo directory.

# Editor and OS noise
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
